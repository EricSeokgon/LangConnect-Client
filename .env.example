# 임베딩 모델을 위한 API 키. 기본값은 OpenAI 임베딩입니다.
OPENAI_API_KEY=

# PostgreSQL 구성
POSTGRES_HOST=teddynote
POSTGRES_PORT=5432
POSTGRES_USER=teddynote
POSTGRES_PASSWORD=teddynote
POSTGRES_DB=teddynote_db

# CORS 구성. 문자열의 JSON 배열이어야 합니다.
ALLOW_ORIGINS=["*"]

# 테스트 모드 (간단한 인증을 위해 true로 설정)
IS_TESTING=false

# 프로덕션 인증 (선택 사항)
SUPABASE_URL=
# 이것은 서비스 역할 키여야 합니다.
SUPABASE_KEY=

# Streamlit 구성
STREAMLIT_PORT=8501

# API 구성
API_BASE_URL=http://localhost:8080

# MCP SSE 서버 구성
SSE_PORT=8765
# MCP 서버를 사용하려면 유효한 Supabase JWT 액세스 토큰을 제공해야 합니다.
# 이 토큰은 Streamlit UI를 통해 로그인한 후 얻을 수 있습니다.
SUPABASE_ACCESS_TOKEN=
